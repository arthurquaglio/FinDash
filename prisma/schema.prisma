// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Para usar Prisma Migrate com Neon (que recomenda usar um shadow DB),
  // defina a variável `SHADOW_DATABASE_URL` com uma conexão válida de shadow DB.
  // Ex: SHADOW_DATABASE_URL="postgresql://..."
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// Modelo de Usuário
model User {
  id           String        @id @default(uuid())
  name         String
  transactions Transaction[]
  budgets      Budget[]
  creditCards  CreditCard[]
  goals        Goal[]        // <-- NOVO: Relação com as Caixinhas/Objetivos
}

// Modelos Globais
model Category {
  id           String        @id @default(uuid())
  name         String
  transactions Transaction[]
  budgets      Budget[]
}

model TransactionType {
  id           String        @id @default(uuid())
  name         String
  transactions Transaction[]
}

// Modelo de Cartão de Crédito
model CreditCard {
  id         String        @id @default(uuid())
  name       String
  closingDay Int
  dueDay     Int

  userId     String
  user       User          @relation(fields: [userId], references: [id])

  transactions Transaction[]
}

// Transações
model Transaction {
  id         String   @id @default(uuid())
  name       String
  value      Float
  date       DateTime

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  typeId     String
  type       TransactionType @relation(fields: [typeId], references: [id])

  userId     String
  user       User     @relation(fields: [userId], references: [id])

  creditCardId String?
  creditCard   CreditCard? @relation(fields: [creditCardId], references: [id])
}

// Metas de Gastos (Limites mensais)
model Budget {
  id         String   @id @default(uuid())
  amount     Float

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  userId     String
  user       User     @relation(fields: [userId], references: [id])

  @@unique([categoryId, userId])
}

// ==========================================
// NOVO: Caixinhas de Objetivos (Poupança)
// ==========================================
model Goal {
  id            String    @id @default(uuid())
  name          String    // Ex: "Viagem a Paris"
  targetAmount  Float     // Ex: 15000 (Quanto quer juntar)
  currentAmount Float     @default(0) // Quanto já tem guardado hoje
  deadline      DateTime? // Opcional: Data limite para atingir a meta

  userId        String
  user          User      @relation(fields: [userId], references: [id])
}